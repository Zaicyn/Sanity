// ============================================================================
// Stellar death constants
// ============================================================================

const uint PFLAG_ACTIVE   = 0x01u;
const uint PFLAG_EJECTED  = 0x02u;
const uint PFLAG_CRYSTAL  = 0x08u;
const uint PFLAG_NOVA     = 0x10u;  // supernova ejecta — ballistic, gravity only

const float OMEGA_SUPERNOVA = 0.65;  // phase velocity -> detonation
const float OMEGA_CRYSTAL   = 0.008; // phase velocity -> heat death
const float DENSITY_MIN_SN  = 0.2;   // density gate for supernova (no vacuum noise)
const float BLAST_MULT      = 2.5;   // supernova kick = BLAST_MULT * omega_nat

// Omega evolution: driven-damped relaxation toward local equilibrium
const float OMEGA_BASE     = 0.08;  // natural floor (slightly below init 0.1)
const float OMEGA_GAIN     = 1.2;   // density coupling → target omega
const float OMEGA_RESPONSE = 0.5;   // relaxation rate toward target
const float OMEGA_DECAY    = 0.15;  // COAST exponential decay rate
const float OMEGA_MAX      = 2.0;   // hard clamp

// ============================================================================
// Fused projection — Tsoding x/z, y/z + density accumulation
// ============================================================================

void fused_project(float wx, float wy, float wz, uint f) {
    // Render mode filtering
    bool is_nova    = (f & PFLAG_NOVA) != 0u;
    bool is_crystal = (f & PFLAG_CRYSTAL) != 0u;
    bool is_alive   = !is_nova && !is_crystal;

    if (pc.render_mode == 1 && !is_alive)   return;
    if (pc.render_mode == 2 && !is_nova)    return;
    if (pc.render_mode == 3 && !is_crystal) return;

    float cx = cam.view_proj[0][0] * wx
             + cam.view_proj[1][0] * wy
             + cam.view_proj[2][0] * wz
             + cam.view_proj[3][0];
    float cy = cam.view_proj[0][1] * wx
             + cam.view_proj[1][1] * wy
             + cam.view_proj[2][1] * wz
             + cam.view_proj[3][1];
    float cw = cam.view_proj[0][3] * wx
             + cam.view_proj[1][3] * wy
             + cam.view_proj[2][3] * wz
             + cam.view_proj[3][3];

    if (cw <= 0.0) return;

    float inv_w = 1.0 / cw;
    float nx = cx * inv_w;
    float ny = cy * inv_w;

    if (abs(nx) > 1.0 || abs(ny) > 1.0) return;

    int px = int((nx * 0.5 + 0.5) * float(cam.width));
    int py = int((ny * 0.5 + 0.5) * float(cam.height));

    if (px >= 0 && px < cam.width && py >= 0 && py < cam.height) {
        if (imageLoad(density_buf, ivec2(px, py)).r > 4096u) return;
        uint contrib = uint(pc.brightness * 32.0);
        imageAtomicAdd(density_buf, ivec2(px, py), max(contrib, 1u));
    }
}

// ============================================================================
// Main kernel — mode-branched execution
// ============================================================================

void main() {
    uint dispatch_id = gl_GlobalInvocationID.x;
    if (dispatch_id >= pc.N) return;

    uint i = dispatch_id;  /* direct indexing — sort_index indirection measured slower on Turing */
    uint f = flags[i];
    if ((f & PFLAG_ACTIVE) == 0u) return;
    if ((f & PFLAG_EJECTED) != 0u) return;
    if ((f & PFLAG_CRYSTAL) != 0u) return;  // frozen remnant, skip entirely

    // ---- Supernova ejecta: ballistic trajectory, gravity only, no fiber ----
    if ((f & PFLAG_NOVA) != 0u) {
        float px = pos_x[i];
        float py = pos_y[i];
        float pz = pos_z[i];
        float vx = vel_x[i];
        float vy = vel_y[i];
        float vz = vel_z[i];

        float r3d_sq  = px*px + py*py + pz*pz;
        float inv_r3d = inversesqrt(r3d_sq + 1e-8);
        float inv_r   = min(inv_r3d, 1.0);
        float gravity  = pc.BH_MASS * inv_r * inv_r;

        vx -= (px * inv_r) * gravity * pc.dt;
        vy -= (py * inv_r) * gravity * pc.dt;
        vz -= (pz * inv_r) * gravity * pc.dt;

        if (isinf(vx) || isnan(vx) || isinf(vy) || isnan(vy) || isinf(vz) || isnan(vz))
            return;

        float fx = px + vx * pc.dt;
        float fy = py + vy * pc.dt;
        float fz = pz + vz * pc.dt;
        pos_x[i] = fx; pos_y[i] = fy; pos_z[i] = fz;
        vel_x[i] = vx; vel_y[i] = vy; vel_z[i] = vz;
        fused_project(fx, fy, fz, f);
        return;
    }

    // ---- Load minimal state (all modes need this) ----
    float px = pos_x[i];
    float py = pos_y[i];
    float pz = pos_z[i];
    float vx = vel_x[i];
    float vy = vel_y[i];
    float vz = vel_z[i];

    // ---- Advance fiber phase (no grid read needed) ----
    float omega = omega_nat[i];
    float theta_i = theta[i] + omega * pc.dt;
    if (theta_i >= 6.28318530718) theta_i -= 6.28318530718;
    if (theta_i < 0.0)           theta_i += 6.28318530718;

    // ---- Mode from ring position ----
    int gen = int(theta_i * 5.09295817894) & 31;
    int mode = FLOW_MODE[gen];

    // ---- Distances (all modes need gravity) ----
    float r3d_sq  = px*px + py*py + pz*pz;
    float inv_r3d = inversesqrt(r3d_sq + 1e-8);
    float r3d     = r3d_sq * inv_r3d;
    float r_safe  = max(r3d, 1.0);
    float inv_r   = min(inv_r3d, 1.0);  // 1/r_safe via inversesqrt, clamped

    float rx = px * inv_r;
    float ry = py * inv_r;
    float rz = pz * inv_r;

    float gravity = pc.BH_MASS * inv_r * inv_r;

    float ax = -rx * gravity;
    float ay = -ry * gravity;
    float az = -rz * gravity;

    // ======================================================================
    // COAST (mode 0): gravity only — predicted Kepler orbit at 1/4 rate.
    // 31% of particles. Physics runs every 4th frame; other frames just
    // project from stored position (no loads beyond pos, no stores).
    // ======================================================================
    if (mode == 0) {
        // Non-physics frames: project only, skip all computation
        #define COAST_STRIDE 4
        if ((pc.frame & (COAST_STRIDE - 1)) != int(i & uint(COAST_STRIDE - 1))) {
            fused_project(px, py, pz, f);
            return;
        }

        // Physics frame: advance COAST_STRIDE steps of ballistic gravity
        float K_dt = pc.dt * float(COAST_STRIDE);

        // ---- Omega decay: K steps of exponential drain ----
        float decay_K = 1.0 - OMEGA_DECAY * pc.dt;
        decay_K = decay_K * decay_K;              // (1-d)^2
        decay_K = decay_K * decay_K;              // (1-d)^4 = (1-d)^COAST_STRIDE
        omega *= decay_K;
        omega = max(omega, 0.0);

        // ---- Crystallization check ----
        float speed_sq = vx*vx + vy*vy + vz*vz;
        if (omega < OMEGA_CRYSTAL && speed_sq < 0.01) {
            vel_x[i] = 0.0;
            vel_y[i] = 0.0;
            vel_z[i] = 0.0;
            omega_nat[i] = 0.0;
            theta[i] = theta_i;
            flags[i] = f | PFLAG_CRYSTAL;
            fused_project(px, py, pz, f | PFLAG_CRYSTAL);
            return;
        }

        // ---- Pressure gradient: feel nearby structure (arms, clusters) ----
        // COAST particles are guided by the density field even without
        // steering/torsion/channels. This is the Viviani field acting on them.
        uint cell = particle_cell[i];
        if (cell < 262144u) {
            float gx = pressure_x[cell];
            float gy = pressure_y[cell];
            float gz = pressure_z[cell];
            float g_dot_r = gx*rx + gy*ry + gz*rz;
            float rho = sqrt(gx*gx + gy*gy + gz*gz);
            float grad_strength = 0.05 * rho;  // gentler than ACTIVE (0.1*rho*envelope)
            ax += (gx - g_dot_r * rx) * grad_strength;
            ay += (gy - g_dot_r * ry) * grad_strength;
            az += (gz - g_dot_r * rz) * grad_strength;
        }

        // ---- Ballistic gravity + field over K steps ----
        // pos(K) = pos + vel*K*dt + 0.5*accel*(K*dt)²
        // vel(K) = vel + accel*K*dt
        // Gravity + field direction constant over K frames (small-angle approx)
        vx += ax * K_dt;
        vy += ay * K_dt;
        vz += az * K_dt;

        if (isinf(vx) || isnan(vx) || isinf(vy) || isnan(vy) || isinf(vz) || isnan(vz))
            return;

        float fx = px + vx * K_dt - ax * 0.5 * K_dt * K_dt;
        float fy = py + vy * K_dt - ay * 0.5 * K_dt * K_dt;
        float fz = pz + vz * K_dt - az * 0.5 * K_dt * K_dt;
        pos_x[i] = fx; pos_y[i] = fy; pos_z[i] = fz;
        vel_x[i] = vx; vel_y[i] = vy; vel_z[i] = vz;
        omega_nat[i] = omega;
        theta[i] = theta_i;
        fused_project(fx, fy, fz, f);
        return;
    }

    // ======================================================================
    // ACTIVE + FLOW paths — need grid, LUT geometry, steering
    // ======================================================================

    // ---- Grid read (ACTIVE + FLOW only) ----
    // Density magnitude computed inline from gradient.
    uint cell = particle_cell[i];
    float gx = 0.0, gy = 0.0, gz = 0.0;
    if (cell < 262144u) {
        gx = pressure_x[cell];
        gy = pressure_y[cell];
        gz = pressure_z[cell];
    }
    float rho = sqrt(gx*gx + gy*gy + gz*gz);

    // ---- Radial envelope: field coherence dilutes with distance from dominant node ----
    // CURVE_PT[gen] is the normalized Viviani curve point for this ring position.
    // The node sits at the same radius as the particle but at the curve's angular position.
    // Transport terms (steering, torsion, gradient) are strong near the node, roll off away.
    #define R_SCALE 25.0
    #define INV_R_SCALE_SQ (1.0 / (R_SCALE * R_SCALE))
    vec3 cp_env = CURVE_PT[gen];
    float dx_n = px - cp_env.x * r_safe;
    float dy_n = py - cp_env.y * r_safe;
    float dz_n = pz - cp_env.z * r_safe;
    float d_node_sq = dx_n*dx_n + dy_n*dy_n + dz_n*dz_n;
    float envelope = inversesqrt(1.0 + d_node_sq * INV_R_SCALE_SQ);

    // ---- Density torsion (ACTIVE + FLOW) ----
    float torsion_boost = 0.5 * rho * envelope;
    theta_i = theta[i] + omega * (1.0 + torsion_boost) * pc.dt;
    if (theta_i >= 6.28318530718) theta_i -= 6.28318530718;
    if (theta_i < 0.0)           theta_i += 6.28318530718;
    gen = int(theta_i * 5.09295817894) & 31;

    // ---- Viviani geometry from LUT ----
    vec3 tang = TANGENT[gen];
    float z_coup = Z_COUPLING[gen];

    // ---- Prograde tangent ----
    float inv_rxz = inversesqrt(px*px + pz*pz + 1e-8);
    float pgx = -pz * inv_rxz;
    float pgz =  px * inv_rxz;

    // ---- Viviani modulation ----
    float f_dot_r = tang.x*rx + tang.y*ry + tang.z*rz;
    float fpx = tang.x - f_dot_r * rx;
    float fpy = tang.y - f_dot_r * ry;
    float fpz = tang.z - f_dot_r * rz;
    float viviani_mod = fpx*pgx + fpz*pgz;

    float tx = pgx * abs(viviani_mod) + fpx * 0.1;
    float ty = fpy * 0.1;
    float tz = pgz * abs(viviani_mod) + fpz * 0.1;

    // ---- EM steering (density-modulated, speed preserved) ----
    float density_gain = 1.0 + 2.0 * rho;
    float base_rate = (mode == 2) ? 0.02 : 0.002;
    float steer_rate = base_rate * density_gain * envelope;

    {
        float speed_sq = vx*vx + vy*vy + vz*vz;
        float inv_speed_before = inversesqrt(speed_sq + 1e-8);

        float inv_t_mag = inversesqrt(tx*tx + ty*ty + tz*tz + 1e-8);
        float tnx = tx * inv_t_mag, tny = ty * inv_t_mag, tnz = tz * inv_t_mag;

        float v_dot_t = vx*tnx + vy*tny + vz*tnz;
        vx -= (vx - v_dot_t * tnx) * steer_rate;
        vy -= (vy - v_dot_t * tny) * steer_rate;
        vz -= (vz - v_dot_t * tnz) * steer_rate;

        float inv_speed_after = inversesqrt(vx*vx + vy*vy + vz*vz + 1e-8);
        float rescale = inv_speed_after / inv_speed_before;
        vx *= rescale;
        vy *= rescale;
        vz *= rescale;
    }

    // ---- Strong channel (ACTIVE + FLOW) ----
    {
        float strong = z_coup * gravity * 0.1;
        ax += rx * strong;
        ay += ry * strong;
        az += rz * strong;
    }

    // ---- Density gradient: tangential deflection (ACTIVE + FLOW) ----
    {
        float g_dot_r = gx*rx + gy*ry + gz*rz;
        float grad_strength = 0.1 * rho * envelope;
        ax += (gx - g_dot_r * rx) * grad_strength;
        ay += (gy - g_dot_r * ry) * grad_strength;
        az += (gz - g_dot_r * rz) * grad_strength;
    }

    // ======================================================================
    // FLOW only — weak channel + curve point attractor
    // ======================================================================
    if (mode == 2) {
        float flow_w = FLOW_W[gen];
        vec3 cp = CURVE_PT[gen];
        float weak_dot_r = cp.x*rx + cp.y*ry + cp.z*rz;
        float weak_strength = abs(flow_w) * gravity * 0.05;
        ax += (cp.x - weak_dot_r * rx) * weak_strength;
        ay += (cp.y - weak_dot_r * ry) * weak_strength;
        az += (cp.z - weak_dot_r * rz) * weak_strength;
    }

    // ---- Integrate ----
    vx += ax * pc.dt;
    vy += ay * pc.dt;
    vz += az * pc.dt;

    if (isinf(vx) || isnan(vx) || isinf(vy) || isnan(vy) || isinf(vz) || isnan(vz))
        return;

    // ======================================================================
    // Omega evolution: driven-damped relaxation (ACTIVE / FLOW)
    // rho = pressure gradient magnitude from the grid (real local density signal)
    // ======================================================================
    {
        float drive = rho * envelope;
        float target = OMEGA_BASE + drive * OMEGA_GAIN;

        // Relax toward density-determined equilibrium
        omega += (target - omega) * OMEGA_RESPONSE * pc.dt;

        // Nonlinear instability boost — sudden ignition above ~0.4
        float instability = max(omega - 0.4, 0.0);
        omega += instability * instability * 0.5 * pc.dt;

        omega = clamp(omega, 0.0, OMEGA_MAX);
    }

    // ======================================================================
    // Stellar death checks — after physics, before writeback
    // ======================================================================

    // ---- Supernova: omega exceeds critical + real density confirms coupling ----
    if (omega > OMEGA_SUPERNOVA && rho > DENSITY_MIN_SN) {
        // Blast kick along fiber tangent, scaled by how supercritical we are
        float blast = BLAST_MULT * omega;
        vec3 tang_kick = TANGENT[gen];

        vx += tang_kick.x * blast;
        vy += tang_kick.y * blast;
        vz += tang_kick.z * blast;

        // Write final state and flag as nova ejecta
        float fx = px + vx * pc.dt;
        float fy = py + vy * pc.dt;
        float fz = pz + vz * pc.dt;
        pos_x[i] = fx; pos_y[i] = fy; pos_z[i] = fz;
        vel_x[i] = vx; vel_y[i] = vy; vel_z[i] = vz;
        omega_nat[i] = OMEGA_SUPERNOVA * 0.5;
        theta[i] = theta_i;
        flags[i] = f | PFLAG_NOVA;
        fused_project(fx, fy, fz, f | PFLAG_NOVA);
        return;
    }

    // ---- Normal writeback + fused projection ----
    float fx = px + vx * pc.dt;
    float fy = py + vy * pc.dt;
    float fz = pz + vz * pc.dt;
    pos_x[i] = fx; pos_y[i] = fy; pos_z[i] = fz;
    vel_x[i] = vx; vel_y[i] = vy; vel_z[i] = vz;
    omega_nat[i] = omega;
    theta[i] = theta_i;
    fused_project(fx, fy, fz, f);
}
