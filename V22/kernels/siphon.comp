// siphon.comp — Squaragon V2 Physics Kernel (mode-branched)
// ==========================================================
//
// Three execution paths gated by flow mode:
//   COAST (31%): gravity + integrate only — no grid, no LUT geometry
//   ACTIVE (44%): gravity + steering + strong channel — grid read
//   FLOW (25%): everything — grid + torsion + all channels + gradient
//
// Zero trig: all Viviani geometry from precomputed LUTs.
// Direct grid sampling: pressure gradient from set 1, no per-particle copies.
//
// Dispatch: ceil(N / 256) workgroups of 256 threads

#version 450

layout(local_size_x = 256) in;

// ============================================================================
// Set 0: SoA particle buffers
// ============================================================================

layout(std430, set = 0, binding = 0)  buffer PosX        { float pos_x[];        };
layout(std430, set = 0, binding = 1)  buffer PosY        { float pos_y[];        };
layout(std430, set = 0, binding = 2)  buffer PosZ        { float pos_z[];        };
layout(std430, set = 0, binding = 3)  buffer VelX        { float vel_x[];        };
layout(std430, set = 0, binding = 4)  buffer VelY        { float vel_y[];        };
layout(std430, set = 0, binding = 5)  buffer VelZ        { float vel_z[];        };
layout(std430, set = 0, binding = 12) buffer Theta       { float theta[];        };
layout(std430, set = 0, binding = 13) buffer OmegaNat    { float omega_nat[];    };
layout(std430, set = 0, binding = 14) buffer Flags       { uint  flags[];        };
// Binding 15 unused — density magnitude computed inline from pressure gradient.

// ============================================================================
// Set 1: pressure grid (direct sampling, no intermediary)
// ============================================================================

layout(std430, set = 1, binding = 0) readonly buffer PCell   { uint  particle_cell[]; };
layout(std430, set = 1, binding = 1) readonly buffer PressX  { float pressure_x[];    };
layout(std430, set = 1, binding = 2) readonly buffer PressY  { float pressure_y[];    };
layout(std430, set = 1, binding = 3) readonly buffer PressZ  { float pressure_z[];    };
layout(std430, set = 1, binding = 4) readonly buffer GDens   { uint  grid_density[];  };
layout(std430, set = 1, binding = 5) readonly buffer SortIdx { uint  sort_index[];    };

// ============================================================================
// Set 2: fused projection (density image + camera UBO)
// ============================================================================

layout(set = 2, binding = 0, r32ui) uniform uimage2D density_buf;

layout(set = 2, binding = 1) uniform CameraUBO {
    mat4  view_proj;
    float zoom;
    float aspect;
    int   width;
    int   height;
} cam;

// ============================================================================
// Push constants
// ============================================================================

layout(push_constant) uniform PushConstants {
    int   N;
    float time;
    float dt;
    float BH_MASS;
    float FIELD_STRENGTH;
    float FIELD_FALLOFF;
    float TANGENT_SCALE;
    uint  seam_bits;
    float bias;
    float brightness;
    int   render_mode;
    int   frame;
} pc;

// ============================================================================
// Squaragon V2 LUTs — precomputed from allocator ground truth
// ============================================================================

